easyblock = 'EB_ApptainerImage'

name = 'claudecode'
version = '2.1.80'

homepage = 'https://www.npmjs.com/package/@anthropic-ai/claude-code'
description = """
Claude Code is an agentic coding tool that lives in your terminal, understands your codebase, and helps you code faster by executing routine tasks, explaining complex code, and handling git workflows -- all through natural language commands. This container includes Ollama for local LLM inference.
"""

toolchain = {'name': 'apptainer', 'version': '1.4.5'}

sources = ['%(name)s-%(version)s.sif']

skipsteps = ['sanitycheck']


modloadmsg = """                                                                                          
    Usage: apptainer run $CONTAINERDIR/claudecode-%(version)s.sif [OPTIONS]

    Options:
      -k, --api-key KEY       API key for UVA LLM integration
      -m, --model-path PATH   Path to local models for bind mount
      -h, --help              Show this help message

    Examples:

      apptainer run $CONTAINERDIR/claudecode-%(version)s.sif
          # Run with default Anthropic settings

      apptainer run $CONTAINERDIR/claudecode-%(version)s.sif -k my-api-key
          # Run with UVA LLM API (Kimi K2.5)

      apptainer run --nv --bind /path/to/models:/ollama_models $CONTAINERDIR/claudecode-%(version)s.sif -m /ollama_models
          # Local model mode with GPU support

    Note: GPU access (--nv flag) is required for running local models (-m flag)
  """
  
moduleclass = 'ai'
